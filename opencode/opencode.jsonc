{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/gpt-5.3-codex",
  "small_model": "google/gemini-3.1-flash-lite-preview",

  "plugin": ["opencode-gemini-auth@latest"],

  "autoupdate": true,

  //"mcp": {
  //  "playwright": {
  //    "type": "local",
  //    "command": [
  //        "pnpm",
  //        "dlx",
  //        "@playwright/mcp@latest",
  //        "--headless",
  //    ],
  //    "enabled": true
  //  },
  //},
  "tools": {
      "playwright*": false,
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.envrc": "deny",
    },
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git show *": "allow",
      "git switch *": "allow",
      "git log*": "allow",
      "git fetch*": "allow",
      "git branch": "allow",
      "git branch --show-current": "allow",
      "git stash*": "allow",
      "./tools/*": "allow",
      "./tools/mypy.sh .": "allow",
      "bazel help": "allow",
      "bazel query*": "allow",
      "bazel test*": "allow",
      "bazel build*": "allow",
      "bazel run //:gazelle*": "allow",
      "bazel run :gazelle*": "allow",
      "go fmt*": "allow",
      "pwd": "allow",
      "ls*": "allow",
      "mkdir *": "allow",
      "grep *": "allow",
      "sort*": "allow",
      "uniq*" : "allow",
      "cut*" : "allow",
      "rg *": "allow",
      "file *": "allow",
      "wc *": "allow",
      "jq*": "allow",
      "yq*": "allow",
      "timeout *": "allow",
      "echo *": "allow",
      // it's ok to use head as part of a pipe, as long as it doesn't refer a filepath
      "head": "allow",
      "head -?": "allow",
      "head -??": "allow",
      "head -???": "allow",
      "tail": "allow",
      "kubectl config current-context": "allow",
      "kubectl get*": "allow",
      "kubectl describe*": "allow",
      "kubectl logs*": "allow",
      "helm list*": "allow",
      "gh pr list*": "allow",
      "psql -c \"\\conninfo\"": "allow",
      "psql -c \"\\l\"": "allow",
      "find* *-exec*": "ask",
      "find* *-execdir*": "ask",
      "find* *-ok*": "ask",
      "find* *-delete*": "ask",
      "find*": "ask",
    },
  },
  "provider": {
    //"litellmproxy": {
    //  "npm": "@ai-sdk/openai-compatible",
    //  "name": "LiteLLM Proxy",
    //  "options": {
    //    "baseURL": "http://0.0.0.0:4000",
    //    "apiKey": "sk-1234"
    //  },
    //  "models": {
    //    "gpt-4.1": {
    //      "name": "GPT 4.1 - LiteLLM"
    //    }
    //  }
    //},
  }
}
