FROM agentbox

USER root

ARG KUBECTL_VERSION=v1.30.5
RUN curl -fsSLo /usr/local/bin/kubectl "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" \
    && chmod 0755 /usr/local/bin/kubectl \
    && kubectl version --client=true

RUN apt-get update \
    && apt-get install -y --no-install-recommends unzip \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSLo /tmp/awscliv2.zip "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install \
    && rm -rf /tmp/aws /tmp/awscliv2.zip \
    && aws --version

RUN curl https://cli.sentry.dev/install -fsS | bash \
    && install -m 0755 /root/.sentry/bin/sentry /usr/local/bin/sentry \
    && sentry --version

RUN install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
      | gpg --dearmor -o /etc/apt/keyrings/google-cloud.gpg \
    && chmod a+r /etc/apt/keyrings/google-cloud.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/google-cloud.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
      > /etc/apt/sources.list.d/google-cloud-sdk.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends google-cloud-cli \
    && rm -rf /var/lib/apt/lists/*

RUN cat <<'EOF' >> /etc/bash.bashrc

# Auto-activate mounted gcloud service-account key in diagnostic containers.
if [[ -z "${AGENTBOX_GCLOUD_AUTH_ACTIVATED:-}" && -r /tmp/gcloud-key.json ]] && command -v gcloud >/dev/null 2>&1; then
  export AGENTBOX_GCLOUD_AUTH_ACTIVATED=1
  gcloud auth activate-service-account --key-file=/tmp/gcloud-key.json --quiet >/dev/null 2>&1 || true
fi
EOF

USER dev
WORKDIR /workspace
